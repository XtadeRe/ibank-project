# Основные настройки
STACK_NAME=${STACK_NAME}
APP_ENV=development
APP_DEBUG=true

# Настройки БД
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_ROOT_PASSWORD=${DB_ROOT_PASSWORD}
DB_PORT=3306

# Порты будут выбраны автоматически из диапазонов в docker-compose
API_PORT=8001
REDIS_PORT=6380
IB_PORT=8082

# Версии
PHP_VERSION=8.2
MYSQL_VERSION=8.0
